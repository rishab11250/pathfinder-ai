# Environment variables required for the Next.js application

# Node.js environment
NODE_ENV="development"

# PostgreSQL Database
# Example: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/pathfinder-ai"

# Google Gemini API
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Redis (Upstash)
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_STORE="auto"
RATE_LIMIT_REDIS_PREFIX="pathfinder:rate-limit"
CACHE_STORE="auto"
CACHE_REDIS_PREFIX="pathfinder:cache"
CACHE_TTL_MS=600000

# Proxy configuration
TRUSTED_PROXY_COUNT=1

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NOTE: NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL / AFTER_SIGN_UP_URL are deprecated in Clerk v5.
# Use fallbackRedirectUrl on <SignIn> component instead.

# Inngest (Background Job Processing)
# Required in production for background jobs (industry insights, rate limit cleanup, etc.)
# Optional in development - the app will start without these keys
# For local development with Inngest dev server, set both to: local
# For production, get keys from: https://app.inngest.com → your app → Manage
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Resend (Interview Reminder Emails)
RESEND_API_KEY=""

# CORS
ALLOWED_ORIGINS=""
CORS_ORIGIN=""

# Development Authentication Bypass (USE ONLY FOR LOCAL DEVELOPMENT)
# ⚠️ SECURITY WARNING: Never set this to "true" in production!
# When set to "true", authentication is bypassed for local development only.
# This requires:
# - NODE_ENV=development
# - Request from localhost or 127.0.0.1
# The application will throw an error if these conditions are not met.
# Remove this variable or set to "false" for production deployments.
SKIP_AUTH="false"
